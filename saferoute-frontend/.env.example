# Copy to .env — Vite exposes only vars prefixed with VITE_
#
# ─── Backend API URL ──────────────────────────────────────────────────────────
# LOCAL DEV (recommended): leave empty — the Vite dev server proxies /api → http://localhost:8000
# VITE_API_URL=
#
# Alternative: call the API directly (backend CORS must allow http://localhost:5173)
# VITE_API_URL=http://localhost:8000
#
# Production (Vercel): set VITE_API_URL to your Railway/Render backend URL on Vercel dashboard
# VITE_API_URL=https://your-backend.up.railway.app
#
# ─── Supabase ─────────────────────────────────────────────────────────────────
# Supabase project URL (safe to expose — it's the public project endpoint)
VITE_SUPABASE_URL=https://djginnuhavnpwvcdbpfp.supabase.co
# Supabase anon/publishable key (safe to expose — RLS policies protect your data)
