# SafeRoute environment variables
# Copy to .env and fill in your actual values
# NEVER commit .env to git!

# ─── Database ────────────────────────────────────────────────────────────────
# Local dev (SQLite, no setup needed):
DATABASE_URL=sqlite:///./saferoute.db

# Production (Supabase PostgreSQL):
# DATABASE_URL=postgresql://postgres:[YOUR-SERVICE-ROLE-PASSWORD]@db.djginnuhavnpwvcdbpfp.supabase.co:5432/postgres

# ─── Supabase (optional direct client) ───────────────────────────────────────
SUPABASE_URL=https://djginnuhavnpwvcdbpfp.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ─── OpenRouteService ─────────────────────────────────────────────────────────
# Free tier: 2000 req/day — https://openrouteservice.org/dev/#/signup
OPENROUTESERVICE_API_KEY=your_openrouteservice_api_key_here

# ─── Twilio SMS ───────────────────────────────────────────────────────────────
# Free trial: ~$15 credit (~100 SMS) — https://www.twilio.com/try-twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ─── Safety Scorer Flags ──────────────────────────────────────────────────────
# SAFETY_IGNORE_CRIME=1   → score routes from safe spots only (no crime_incidents)
# SAFETY_USE_OSM_FILE=1   → load OSM infrastructure from data/export.geojson file

# ─── App Settings ─────────────────────────────────────────────────────────────
APP_ENV=development
# Add your Vercel frontend URL to CORS_ORIGINS when deploying:
CORS_ORIGINS=http://localhost:5173,https://saferoute-asean.vercel.app
